# Vigil Backend — Environment Variables
# Run `npm run reveal-secrets` from the repo root to scaffold this file.
# NEVER commit .env to git.

# AWS — IAM user with read-only Glue + CloudWatch access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# SendGrid — for anomaly alert emails
SENDGRID_API_KEY=
ALERT_SENDER_EMAIL=

# PostgreSQL — use Supabase Session Mode pooler (port 5432, NOT 6543)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Login credentials
# Generate password hash with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
VIGIL_USERNAME=
VIGIL_PASSWORD_HASH=

# CORS — comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173
# Production: your Vercel URL
ALLOWED_ORIGINS=http://localhost:5173
